{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "codex_switch",
  "version": "../package.json",
  "identifier": "com.cmochance.codexswitch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist/web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Switch",
        "width": 900,
        "height": 540,
        "minWidth": 900,
        "minHeight": 540,
        "resizable": true,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERDNzVFNDZEQUQ3NzQ4ODkKUldTSlNIZXRiZVIxM0FaZ1hNWVFpRit5V01NWk4zeWNydXI3dnZUYml2aEdld2l6Yzk4OU54eGgK",
      "endpoints": [
        "https://github.com/ChArLiEdance/codex-switch/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
