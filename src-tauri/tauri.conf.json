{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "codex_switch",
  "version": "../package.json",
  "identifier": "com.cmochance.codexswitch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist/web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Switch",
        "width": 747,
        "height": 480,
        "minWidth": 747,
        "minHeight": 480,
        "resizable": true,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
