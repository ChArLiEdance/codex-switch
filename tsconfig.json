{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@front-shared/*": ["src-tauri/shared/front/*"],
      "@win-front/*": ["src-tauri/win/front/*"],
      "@mac-front/*": ["src-tauri/mac/front/*"]
    },
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src-tauri/win/front", "src-tauri/mac/front", "src-tauri/shared/front"]
}
